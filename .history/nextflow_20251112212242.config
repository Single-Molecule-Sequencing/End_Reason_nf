/*
 * Nextflow configuration file for End Reason Tagging Pipeline
 */

// Manifest information
manifest {
    name            = 'end_reason_tagger'
    author          = 'kmathew (imported by gregfar)'
    description     = 'Pipeline to tag BAM files with end_reason metadata from POD5 files'
    mainScript      = 'main.nf'
    nextflowVersion = '>=21.04.0'
    version         = '1.0.0'
}
    name            = 'Single-Molecule-Sequencing/wf-end-reason'
    author          = 'Single-Molecule-Sequencing'
    homePage        = 'https://github.com/Single-Molecule-Sequencing/End_Reason_nf'
    description     = 'Pipeline to tag BAM files with end_reason metadata from POD5 files'
    nextflowVersion = '>=23.04.0'
    version         = 'v1.0.0'


epi2melabs {
    tags = 'wf-end-reason,bam,pod5,tagging,quality-control'
    icon = 'faTags'
}
// Default parameters
params {
    // Input/Output
    pod5_dir = null
    pod5_json = null
    bam_input = null
    outdir = './results'
    write_pod5_json = null
    log_level = 'INFO'

    // Help
    help = false
    version = false

    // Hidden/default params expected by EPI2ME Desktop
    process_label = 'wf_end_reason'
    aws_image_prefix = null
    aws_queue = null
    monochrome_logs = false
    validate_params = true
    show_hidden_params = false
    schema_ignore_params = 'show_hidden_params,validate_params,monochrome_logs,aws_queue,aws_image_prefix,process_label'
}

// Process configuration
process {
    // Default process settings
    errorStrategy = 'retry'
    maxRetries = 2
    shell = ['/bin/bash', '-euo', 'pipefail']

    // Resource requirements for TAG_END_REASON process
    withName: TAG_END_REASON {
        cpus = 2
        memory = 4.GB
        time = 2.h
    }
}

// Executor configuration
executor {
    name = 'local'
    cpus = 4
    memory = '8 GB'
}

// Conda configuration
conda {
    enabled = true
    useMamba = false
    createTimeout = '1 h'
}

// Profile configurations
profiles {
    // Standard profile (local execution with conda)
    standard {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/envs/tagger.yaml"
    }

    // Local profile (explicit local execution)
    local {
        process.executor = 'local'
        conda.enabled = true
        process.conda = "${projectDir}/envs/tagger.yaml"
    }

    // SLURM profile for HPC execution
    slurm {
        process.executor = 'slurm'
        process.queue = 'standard'
        process.clusterOptions = '--account=atheylab'
        conda.enabled = true
        process.conda = "${projectDir}/envs/tagger.yaml"

        // SLURM-specific process settings
        process {
            withName: TAG_END_REASON {
                cpus = 4
                memory = 8.GB
                time = 4.h
            }
        }
    }

    // Test profile with minimal resources
    test {
        params.outdir = './test_results'
        process {
            withName: TAG_END_REASON {
                cpus = 1
                memory = 2.GB
                time = 30.m
            }
        }
    }
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/reports/trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/reports/dag.html"
    overwrite = true
}
